{
  "manifest_version": 3,
  "name": "Video downloader (yt-dlp local)",
  "version": "1.0.0",
  "icons": { "128": "Koharu.png" },
  "permissions": ["contextMenus", "storage", "activeTab", "tabs", "downloads"],
  "host_permissions": ["http://localhost:8791/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.youtube.com/*", "https://music.youtube.com/*"],
      "js": ["youtube.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["twitter.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.tiktok.com/*"],
      "js": ["tiktok.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.reddit.com/*"],
      "js": ["reddit.js"],
      "run_at": "document_start"
    }
  ]
}
